# Copy this file to .env.local and paste your Firebase web app config.
# These values are NOT secret — they identify your project to the client and are
# protected by the Realtime Database security rules in database.rules.json.
# Find them in Firebase console -> Project settings -> Your apps -> SDK setup.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
